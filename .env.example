# ═══════════════════════════════════════════
#  eLearnBot — Variables d'environnement
#  Duplique ce fichier en .env et complète
#  NE JAMAIS COMMITER .env !
# ═══════════════════════════════════════════

# ── Supabase (base de données + stockage) ─
SUPABASE_URL="https://votre-projet.supabase.co"
SUPABASE_KEY="votre_cle_anon"

# ── LLM (choisir UNE des 3) ──────────────
# OpenAI
# OPENAI_API_KEY="sk-..."
# OU Groq (recommandé, gratuit)
GROQ_API_KEY="gsk_..."
# OU Gemini
# GEMINI_API_KEY="AIza..."

# ── Optionnel ──────────────────────────────
# Modèle LLM par défaut
# LLM_MODEL="llama-3.3-70b-versatile"  # Groq

# Légifrance : clé API PISTE (gratuite sur https://api.piste.gouv.fr)
# PISTE_API_KEY="votre_cle_piste"

# Embeddings : nom du modèle (sentence-transformers)
# EMBEDDING_MODEL="all-MiniLM-L6-v2"

# ChromaDB : chemin de persistance locale
# CHROMA_DB_PATH="./chroma_db"