# ═══════════════════════════════════════════
#  eLearnBot — Variables d'environnement
#  Duplique ce fichier en .env et complète
#  NE JAMAIS COMMITER .env !
# ═══════════════════════════════════════════

# ── Google Drive ──────────────────────────
# ID du dossier Google Drive (dans l'URL)
GOOGLE_DRIVE_FOLDER_ID="votre_id_dossier_drive"

# Chemin vers le fichier JSON du compte de service
# En local : chemin relatif ou absolu
# Sur Streamlit Cloud : utiliser GOOGLE_SERVICE_ACCOUNT_JSON (secret)
GOOGLE_APPLICATION_CREDENTIALS="service_account.json"

# ── LLM (choisir UNE des 3) ──────────────
# OpenAI / Groq (API compatible)
OPENAI_API_KEY="sk-..."
# OU Groq
GROQ_API_KEY="gsk_..."
# OU Gemini
GEMINI_API_KEY="AIza..."

# ── Optionnel ──────────────────────────────
# Modèle LLM par défaut (selon le provider choisi)
LLM_MODEL="llama-3.3-70b-versatile"  # Groq
# LLM_MODEL="gpt-4o-mini"            # OpenAI
# LLM_MODEL="gemini-2.0-flash"       # Gemini

# Embeddings : chemin du modèle local (sentence-transformers)
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# ChromaDB : persistance locale
CHROMA_DB_PATH="./chroma_db"